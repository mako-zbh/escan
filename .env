# ============================================================
# eScan 配置文件 — 复制为 .env.local 并填入真实值
# .env 可提交到 git（不含 secret），.env.local 不可提交
# ============================================================

# --- FOFA 搜索引擎 ---
# 模式一：官方 API key（推荐，优先级高于代理）
# FOFA_KEY=
# 模式二：代理接口 Cookie
#FOFA_API=
# FOFA_PROXY_COOKIE=
# FOFA_SIZE=100

# --- Hunter 搜索引擎 ---
# 模式一：官方 API key（推荐，优先级高于代理）
# HUNTER_API_KEY=
# HUNTER_API=https://hunter.qianxin.com/openApi/search
# 模式二：代理接口 Cookie
# HUNTER_PROXY_API=
# HUNTER_PROXY_COOKIE=
# HUNTER_SIZE=100

# --- 默认搜索引擎 ---
# SEARCH_ENGINE=fofa                        # fofa | hunter

# --- Nuclei 扫描器 ---
# NUCLEI_PATH=                          # nuclei 路径（Windows 例: C:\tools\nuclei.exe），留空自动查找

# --- 爱站 ICP 备案查询 ---
# AIZHAN_COOKIE=                        # 登录 Cookie

# --- MIIT ICP 备案查询 ---
# 使用工信部官方 API，内置本地 IPv6 地址池轮换（Linux/macOS 自动检测）

# --- DeepSeek AI ---
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_API=https://api.deepseek.com/v1/chat/completions

# --- 本地 GLM-OCR（llama.cpp server）---
# GLM_OCR_API=http://127.0.0.1:8080/v1/chat/completions

# --- PostgreSQL 数据库（可选）---
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=vulnscan
# DB_USER=vulnscan
# DB_PASSWORD=

# --- 运行参数 ---
# LOG_LEVEL=INFO                        # DEBUG / INFO / WARNING / ERROR
# AGENT_CONCURRENCY=3                   # 批量转换并发数
# ICP_THREADS=2
# ICP_DELAY=5.0
